# =============================================================================
# PolyCrystExtractor .gitignore
# 原则：数据、模型权重、密钥绝不入仓
# =============================================================================

# ── 数据目录（绝不提交） ────────────────────────────────────────────────────
data/raw_seed_50/
data/vlm_finetune/
data/golden_standard/
data/processed/*
!data/processed/.gitkeep

# ── 模型权重（过大/敏感） ──────────────────────────────────────────────────
*.pt
*.pth
*.safetensors
*.ckpt
*.bin
models/
checkpoints/

# ── 输出与日志 ──────────────────────────────────────────────────────────────
logs/
*.log
output/
results/
*.out

# ── 环境配置 ────────────────────────────────────────────────────────────────
venv/
.env
.env.local
__pycache__/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 大文件 ──────────────────────────────────────────────────────────────────
*.pdf
*.cif
*.docx
*.zip
*.tar.gz
